<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_library_rent_form" model="ir.ui.view">
        <field name="name">library.rent.form</field>
        <field name="model">library.rent</field>
        <field name="arch" type="xml">
            <form string="Rent Record">
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="book_id"/>
                        </group>
                        <group>
                            <field name="rent_date"/>
                            <field name="return_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_library_rent_tree" model="ir.ui.view">
        <field name="name">library.rent.tree</field>
        <field name="model">library.rent</field>
        <field name="arch" type="xml">
            <list string="Rents">
                <field name="book_id"/>
                <field name="partner_id"/>
                <field name="rent_date"/>
                <field name="return_date"/>
            </list>
        </field>
    </record>

    <record id="action_library_rent" model="ir.actions.act_window">
        <field name="name">Rent Records</field>
        <field name="res_model">library.rent</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
